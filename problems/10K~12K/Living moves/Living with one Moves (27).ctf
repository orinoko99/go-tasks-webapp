Dia. 02 Greedy
[{\rtf1\ansi\ansicpg949\deff0{\fonttbl{\f0\fnil\fcharset129 \'b1\'bc\'b8\'b2;}}
{\colortbl ;\red255\green0\blue0;}
\viewkind4\uc1\pard\lang1042\f0\fs18
\par White 1 is a \cf1\b greedy move\cf0\b0 .
\par After Black 2 White can't live anymore.
\par If White connects at A Black can play elsewhere and White is still dead.
\par
\par If White plays at B instead of 1, Black plays the placement at C and White is dead again.
\par
\par
\par }
