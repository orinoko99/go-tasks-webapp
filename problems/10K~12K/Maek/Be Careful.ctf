[{\rtf1\ansi\ansicpg949\deff0{\fonttbl{\f0\fnil\fcharset129 \'b1\'bc\'b8\'b2;}}
{\colortbl ;\red0\green0\blue255;}
\viewkind4\uc1\pard\lang1042\f0\fs18
\par White's placement with 1 at 1-1 is the vital point which captures Black.
\par
\par If Black plays at 2 White's \cf1\b snapback works\cf0\b0  with 3.
\par
