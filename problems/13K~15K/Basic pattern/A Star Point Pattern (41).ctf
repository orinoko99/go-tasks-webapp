[{\rtf1\ansi\ansicpg949\deff0{\fonttbl{\f0\fnil\fcharset129 \'b1\'bc\'b8\'b2;}}
\viewkind4\uc1\pard\lang1042\f0\fs18
\par White should not fear the two white stones in the corner being captured and connect at 1.
\par
\par Black will hane at 2 and try to seal white in.
\par
