[{\rtf1\ansi\ansicpg949\deff0\deflang1033\deflangfe1042{\fonttbl{\f0\fnil\fcharset129 \'b1\'bc\'b8\'b2;}}
\viewkind4\uc1\pard\lang1042\f0\fs18
\par \b White to play\b0 .
\par Checking in an instant, it seems Black is alive.
\par
\par However there is a vital point of this life and death problem.
\par If White finds the first move, he can capture Black.
\par Pae is a failure.
\par }
