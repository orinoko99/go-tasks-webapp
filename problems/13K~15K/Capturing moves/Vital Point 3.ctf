Dia. 03 Pae
[{\rtf1\ansi\ansicpg949\deff0{\fonttbl{\f0\fnil\fcharset129 \'b1\'bc\'b8\'b2;}}
{\colortbl ;\red255\green0\blue0;}
\viewkind4\uc1\pard\lang1042\f0\fs18
\par Attacking from White 1 is \cf1\b impatient\cf0\b0 .
\par Black 2 and White 3 are only moves.
\par After that if Black plays at 4, White makes pae with 5.
\par
\par This was a \cf1\b wrong sequence\cf0\b0 .
\par Starting the attack from 5 is the right order.
\par
\par }
