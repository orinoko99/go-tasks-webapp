Dia. 03 Only Endgame
[{\rtf1\ansi\ansicpg949\deff0{\fonttbl{\f0\fnil\fcharset129 \'b1\'bc\'b8\'b2;}}
{\colortbl ;\red255\green0\blue0;}
\viewkind4\uc1\pard\lang1042\f0\fs18
\par White's attachment at 1 is \cf1\b only\cf0\b0  an \cf1\b endgame move\cf0\b0 .
\par If Black plays at 2, he can live up to 4.
\par
\par
\par
\par }
