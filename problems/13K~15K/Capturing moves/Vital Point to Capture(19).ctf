[{\rtf1\ansi\ansicpg949\deff0{\fonttbl{\f0\fnil\fcharset129 \'b1\'bc\'b8\'b2;}}
{\colortbl ;\red0\green0\blue255;}
\viewkind4\uc1\pard\lang1042\f0\fs18
\par Black's \cf1\b placement \cf0\b0 at 1 is a \cf1\b severe move\cf0\b0 .
\par
\par It is looking at the snapback at A.
\par
\par If White plays at 2, Black blocks with 3 which is a calm move.
\par
\par A and B are miai so White can't live anymore.
\par
\par
