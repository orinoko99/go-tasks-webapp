Dia. 02 White 1, Greedy
[{\rtf1\ansi\ansicpg949\deff0{\fonttbl{\f0\fnil\fcharset129 \'b1\'bc\'b8\'b2;}}
{\colortbl ;\red255\green0\blue0;\red0\green0\blue255;}
\viewkind4\uc1\pard\lang1042\f0\fs18
\par Trying to capture the whole group with White 1 is \cf1\b greedy\cf0\b0 .
\par Black's \cf2\b diagonal move\cf0\b0  at 2 is a \cf2\b good move\cf0\b0 .
\par
\par If Black answers with A instead of 2, White plays at 2 and Black is dead.
\par
\par
\par
