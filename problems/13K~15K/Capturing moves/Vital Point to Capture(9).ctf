Dia. 02 Illusion
[{\rtf1\ansi\ansicpg949\deff0{\fonttbl{\f0\fnil\fcharset129 \'b1\'bc\'b8\'b2;}}
{\colortbl ;\red255\green0\blue0;}
\viewkind4\uc1\pard\lang1042\f0\fs18
\par White 1 is a serious \cf1\b illusion\cf0\b0 .
\par After Black blocks at 2, White's dansu at 3 doesn't work.
\par
\par Black answers at 4 and lives with five points.
\par
\par
\par }
